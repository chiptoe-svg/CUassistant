# ===== Mode =====
# preclassifier  -- DEFAULT. Host runs the deterministic cascade (buckets 1+2).
#                   Residuals go to OpenAI via direct API call when
#                   OPENAI_API_KEY is set; otherwise FALLS BACK to the codex
#                   CLI automatically. So leaving OPENAI_API_KEY blank is fine
#                   if you already have codex authenticated.
# agent          -- Skip the host cascade entirely; let codex classify every
#                   email. Useful for sanity-checking the cascade rules.
# hybrid         -- Host runs buckets 1+2; codex (not OpenAI direct) handles
#                   residuals. Useful when you want a ChatGPT subscription
#                   instead of an API key but still want the cost savings of
#                   the deterministic prefilter.
MODE=preclassifier

# Dry-run: log decisions but do not create MS365 tasks or write progress.yaml
# DRY_RUN=1

# ===== OpenAI (used in MODE=preclassifier and MODE=hybrid for residual classification) =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# ===== Codex CLI (used in MODE=agent and MODE=hybrid) =====
# Path to the codex binary. Leave blank to use `codex` from PATH.
CODEX_BIN=
CODEX_MODEL=gpt-5.4-mini

# ===== Microsoft 365 (Outlook + To Do) =====
# Register an app in Azure AD with delegated Mail.Read, Mail.ReadWrite, Tasks.ReadWrite.
# Run `npm run scripts/ms365-login` once to get the refresh token.
MS365_CLIENT_ID=
MS365_TENANT_ID=common
MS365_REFRESH_TOKEN=

# ===== Google Workspace (optional — Gmail listing) =====
# Path to gws CLI binary; leave blank to skip Gmail.
GWS_BIN=

# ===== Paths =====
# Where YAML config lives (defaults to ./config)
# CONFIG_DIR=
# Where state files (decisions.jsonl, progress.yaml, tasks.json) live (defaults to ./state)
# STATE_DIR=
