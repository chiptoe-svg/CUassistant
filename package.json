{
  "name": "cuassistant",
  "version": "0.1.0",
  "private": true,
  "description": "Cron-driven email triage that uses Codex classification and host-created MS365 To Do tasks.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "scan": "tsx src/index.ts",
    "scan:dry": "DRY_RUN=1 tsx src/index.ts",
    "mcp": "tsx src/mcp-server.ts",
    "ms365-login": "tsx scripts/ms365-login.ts",
    "graph-cli-tasks-login": "tsx scripts/graph-cli-tasks-login.ts",
    "provider-smoke": "tsx scripts/provider-smoke.ts",
    "tasks:cleanup-noise": "tsx scripts/cleanup-task-noise.ts",
    "cost-report": "tsx scripts/cost-report.ts",
    "preclassify:suggest": "tsx scripts/preclassify-suggest.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"*.{md,json}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{md,json}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "husky": "^9.1.7",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
