{
  "name": "cuassistant",
  "version": "0.1.0",
  "private": true,
  "description": "Cron-driven email triage that uses Codex classification and host-created MS365 To Do tasks.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "scan": "tsx src/index.ts",
    "scan:dry": "DRY_RUN=1 tsx src/index.ts",
    "mcp": "tsx src/mcp-server.ts",
    "mcp:http": "MCP_TRANSPORT=http tsx src/mcp-server.ts",
    "mcp:public": "tsx src/mcp-public.ts",
    "mcp:public:http": "MCP_TRANSPORT=http tsx src/mcp-public.ts",
    "mcp:catalog": "tsx src/mcp-catalog.ts",
    "mcp:catalog:http": "MCP_TRANSPORT=http tsx src/mcp-catalog.ts",
    "advisor": "tsx src/advisor-server.ts",
    "portal": "tsx src/token-portal.ts",
    "portal:start": "TOKEN_PORTAL_BASE_URL=http://localhost:8769 tsx src/token-portal.ts",
    "mcp:pair": "tsx scripts/mcp-consumers.ts",
    "mcp:consumers": "tsx scripts/mcp-consumers.ts",
    "ms365-login": "tsx scripts/ms365-login.ts",
    "provider-smoke": "tsx scripts/provider-smoke.ts",
    "clemson:refresh": "tsx scripts/clemson-refresh.ts",
    "clemson:convert": "tsx scripts/clemson-convert-snapshots.ts",
    "audit:verify": "tsx scripts/verify-audit.ts",
    "gws:grant": "tsx scripts/gws-grant.ts",
    "tasks:cleanup-noise": "tsx scripts/cleanup-task-noise.ts",
    "cost-report": "tsx scripts/cost-report.ts",
    "preclassify:suggest": "tsx scripts/preclassify-suggest.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"*.{md,json}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{md,json}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.75.4",
    "@earendil-works/pi-ai": "^0.75.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "^12.11.1",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "husky": "^9.1.7",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
