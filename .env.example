# ===== Mode =====
# agent         -- DEFAULT. Codex classifies every email. This is the
#                  source-of-truth behavior.
# hybrid        -- Host applies deterministic shortcuts first; the selected
#                  residual classifier handles everything not resolved.
# compare       -- No task/progress side effects. Codex classifies every email
#                  and logs how deterministic shortcuts would compare. Use
#                  before `npm run preclassify:suggest`.
MODE=agent

# Dry-run: log decisions but do not create MS365 tasks or write progress.yaml
# DRY_RUN=1

# Optional bounded catch-up window. Use for backfills instead of editing
# state/progress.yaml by hand. Progress does not advance unless explicitly set.
# BACKFILL_FROM=2026-04-27T00:00:00-04:00
# BACKFILL_TO=2026-04-28T00:00:00-04:00
# BACKFILL_ADVANCE_PROGRESS=1

# ===== Codex CLI / ChatGPT Edu path =====
# Path to the codex binary. Leave blank to use `codex` from PATH.
CODEX_BIN=
CODEX_MODEL=gpt-5.4-mini
# Kill a Codex classifier run if it hangs.
CODEX_TIMEOUT_MS=90000
# Split classifier work after mail listing. Smaller batches reduce timeout
# blast radius during catch-up windows.
CLASSIFIER_BATCH_SIZE=10

# ===== Residual classifier backend (MODE=hybrid only) =====
# codex  -- DEFAULT. Residuals go through Codex (ChatGPT Edu, institutional).
# openai -- Residuals go through a lean direct OpenAI API call. No tools.
RESIDUAL_CLASSIFIER=codex
OPENAI_API_KEY=
OPENAI_CLASSIFIER_MODEL=gpt-5.4-mini
OPENAI_CLASSIFIER_TIMEOUT_MS=20000
# The openai path sends mailbox content to the OpenAI API — OUTSIDE the M365 /
# ChatGPT-Edu data envelope. It is blocked unless you explicitly acknowledge the
# egress here, which you should only do after confirming DPA/FERPA coverage for
# that destination. The Codex path is unaffected.
# OPENAI_EGRESS_ACK=1

# ===== Microsoft 365 (Outlook + To Do + Calendar) =====
# The GCassistant Azure AD app is the single Graph backend (see
# src/provider-registry.ts). Consented scopes: delegated Mail.ReadWrite,
# Tasks.ReadWrite, Calendars.ReadWrite — the token requests all three. The scan
# handler uses mail read + To Do; the MCP server additionally exposes mail and
# calendar writes, each gated by policy/action-policy.yaml (destructive or
# affects-others actions stay approval=human_required). Gmail (gws) is the only
# alternate mail source and is selected per-account in config, not by an env
# switch. Run `npm run ms365-login` once to get the refresh token.
MS365_CLIENT_ID=
MS365_TENANT_ID=common
MS365_REFRESH_TOKEN=

# The mail-move MCP tool requires this explicit folder allow-list and fails
# closed without it. Values are compared case-insensitively against
# destinationId / wellKnownName.
# MCP_ALLOWED_MAIL_DESTINATIONS=archive,/teaching/courses

# ===== Google Workspace (optional — Gmail listing) =====
# Path to gws CLI binary; leave blank to skip Gmail.
GWS_BIN=

# ===== Paths =====
# Where YAML config lives (defaults to ./config)
# CONFIG_DIR=
# Where state files live (defaults to ./state)
# STATE_DIR=

# ===== Send-mail approval gate =====
# Telegram bot that delivers send approvals and collects your tap.
TELEGRAM_BOT_TOKEN=
TELEGRAM_APPROVER_USER_ID=
# Optional tuning:
# SEND_APPROVAL_TTL_MS=3600000
# SEND_APPROVAL_MAX_OUTSTANDING=5
# SEND_APPROVAL_RATE_PER_HOUR=10
# SEND_INTERNAL_DOMAINS=clemson.edu
