{
  "name": "email-taskfinder",
  "version": "0.1.0",
  "private": true,
  "description": "Stripped-down email taskfinder: cron-driven inbox cascade that creates MS365 To Do tasks for actionable mail.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "scan": "tsx src/index.ts",
    "scan:dry": "DRY_RUN=1 tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"*.{md,json}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{md,json}\""
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
