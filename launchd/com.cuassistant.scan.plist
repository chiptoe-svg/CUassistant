    <dict>
      <key>Hour</key><integer>16</integer>
      <key>Minute</key><integer>0</integer>
      <key>Weekday</key><integer>5</integer>
    </dict>
  </array>

  <key>StandardOutPath</key>
  <string>HOME_PATH/Library/Logs/cuassistant.scan.out.log</string>
  <key>StandardErrorPath</key>
  <string>HOME_PATH/Library/Logs/cuassistant.scan.err.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
