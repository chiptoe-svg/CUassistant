<?xml version="1.0" encoding="UTF-8"?>
<!--
  CUassistant Clemson snapshot refresh job for launchd.

  Refreshes the per-term class snapshots (state/clemson/<term>.json) once a day
  by discovering the live terms via Banner's getTerms. New terms (e.g. Spring
  2027) are picked up automatically; "(View Only)" terms are skipped.

  Setup (one time):
    1. Edit this file: replace REPO_PATH with the absolute path to your local
       repo, NPM_PATH with the absolute path to your npm binary
       (run `which npm`), and HOME_PATH with $HOME.
    2. cp launchd/com.cuassistant.clemson-refresh.plist ~/Library/LaunchAgents/
    3. launchctl load ~/Library/LaunchAgents/com.cuassistant.clemson-refresh.plist
    4. (optional) launchctl start com.cuassistant.clemson-refresh  # run once now
    5. tail -f ~/Library/Logs/cuassistant.clemson.out.log

  Schedule: 5:00 AM daily. Edit StartCalendarInterval to change cadence.

  To unload:
    launchctl unload ~/Library/LaunchAgents/com.cuassistant.clemson-refresh.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.cuassistant.clemson-refresh</string>

  <key>ProgramArguments</key>
  <array>
    <string>NPM_PATH</string>
    <string>run</string>
    <string>clemson:refresh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>REPO_PATH</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>HOME_PATH</string>
  </dict>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>5</integer>
    <key>Minute</key><integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>HOME_PATH/Library/Logs/cuassistant.clemson.out.log</string>
  <key>StandardErrorPath</key>
  <string>HOME_PATH/Library/Logs/cuassistant.clemson.err.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
