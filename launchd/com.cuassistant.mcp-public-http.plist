<?xml version="1.0" encoding="UTF-8"?>
<!--
  CUassistant PUBLIC MCP server (HTTP) service for launchd.

  Runs the public-DATA HTTP MCP server, exposing only the Clemson
  class-schedule tools (public Banner data).

  AUTH (required): this server is CAMPUS-REACHABLE and authenticates every
  request against MCP_PUBLIC_AUTH_TOKEN — its own bearer, distinct from the
  catalog server's key and from anything on 8765. The key lives in the repo's
  gitignored .env; do NOT write it into this plist. With the key unset the
  process refuses to start rather than serving open.

  BIND: MCP_PUBLIC_HTTP_HOST (default 127.0.0.1; set to 0.0.0.0 in .env for
  campus reach). Deliberately NOT MCP_HTTP_HOST, which is shared with the
  credentialed server on 8765 and must stay on loopback.

  NOTE: the MCP HTTP transport performs no Host/Origin validation, so off
  loopback the bearer is the ONLY gate — there is no rebinding protection.

  A containerized NanoClaw agent reaches it via host.docker.internal:8766
  and must now send `Authorization: Bearer <MCP_PUBLIC_AUTH_TOKEN>`. The
  credentialed server (port 8765) is a separate, loopback-only process; see
  com.cuassistant.mcp-http.plist.

  Ports are tracked in ~/.dev-ports.yaml (cuassistant: mcp_credentialed 8765,
  mcp_public 8766).

  Setup (one time):
    1. Edit this file: replace REPO_PATH with the absolute path to your
       local repo, NPM_PATH with the absolute path to your npm binary
       (run `which npm`), and HOME_PATH with $HOME.
    2. cp launchd/com.cuassistant.mcp-public-http.plist ~/Library/LaunchAgents/
    3. launchctl load ~/Library/LaunchAgents/com.cuassistant.mcp-public-http.plist
    4. (optional) launchctl start com.cuassistant.mcp-public-http  # bring up now
    5. tail -f ~/Library/Logs/cuassistant.mcp-public.out.log

  The service starts automatically at login and is kept alive by launchd.
  MCP_PUBLIC_HTTP_PORT defaults to 8766 if not set in the environment.

  To unload:
    launchctl unload ~/Library/LaunchAgents/com.cuassistant.mcp-public-http.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.cuassistant.mcp-public-http</string>

  <key>ProgramArguments</key>
  <array>
    <string>NPM_PATH</string>
    <string>run</string>
    <string>mcp:public:http</string>
  </array>

  <key>WorkingDirectory</key>
  <string>REPO_PATH</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>HOME_PATH</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>HOME_PATH/Library/Logs/cuassistant.mcp-public.out.log</string>
  <key>StandardErrorPath</key>
  <string>HOME_PATH/Library/Logs/cuassistant.mcp-public.err.log</string>
</dict>
</plist>
